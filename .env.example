# Core project
RENTPULSE_ENV=dev
RENTPULSE_SOURCE_FILE=config/sources.json
RENTPULSE_LOCAL_TMP_DIR=.tmp/rentpulse

# AWS credentials (optional if you already use `aws configure` — boto3 reads these when set)
# Never commit real values; keep them only in .env (gitignored).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Optional production listing feed override.
# Use an approved public CSV/JSON feed with listing_id, snapshot_date, rent, amenities, and location fields.
RENT_PULSE_LISTINGS_URL=

# AWS: Amazon S3, AWS Glue, Amazon Athena, AWS QuickSight
AWS_REGION=us-east-1
# Leave empty to auto-pick a bucket in scripts/bootstrap_aws.sh, or set your bucket name.
RENTPULSE_S3_BUCKET=
RENTPULSE_S3_PREFIX=rentpulse
RENTPULSE_GLUE_DATABASE=rentpulse_raw
RENTPULSE_GLUE_ROLE_ARN=arn:aws:iam::123456789012:role/rentpulse-glue-crawler-role
RENTPULSE_GLUE_CRAWLER_NAME=rentpulse-normalized-crawler
RENTPULSE_ATHENA_WORKGROUP=primary
RENTPULSE_ATHENA_OUTPUT=s3://your-rentpulse-query-results/athena/
RENTPULSE_ATHENA_RAW_TABLE=raw_records
RENTPULSE_QUICKSIGHT_AWS_ACCOUNT_ID=123456789012
RENTPULSE_QUICKSIGHT_NAMESPACE=default
RENTPULSE_QUICKSIGHT_DATASET_IDS=rentpulse-neighborhood-scorecard,rentpulse-rent-trends,rentpulse-affordability,rentpulse-development-activity,rentpulse-transit-price-effect
RENTPULSE_QUICKSIGHT_DASHBOARD_ID=rentpulse-public-dashboard
RENTPULSE_QUICKSIGHT_SHARE_PRINCIPAL_ARN=

# Postgres staging
RENTPULSE_POSTGRES_URL=postgresql://rentpulse:rentpulse@localhost:5432/rentpulse

# Snowflake warehouse
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_USER=RENTPULSE_LOADER
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=RENTPULSE_ROLE
SNOWFLAKE_WAREHOUSE=RENTPULSE_WH
SNOWFLAKE_DATABASE=RENTPULSE
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_STORAGE_INTEGRATION=RENTPULSE_S3_INT
SNOWFLAKE_S3_STAGE_NAME=RENTPULSE_RAW_STAGE

# dbt Cloud
DBT_CLOUD_ACCOUNT_ID=12345
DBT_CLOUD_JOB_ID=67890
DBT_CLOUD_API_TOKEN=
